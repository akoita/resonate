{
  "name": "resonate",
  "private": true,
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint:staged": "lint-staged",
    "security:lock-sources": "node scripts/check-npm-lock-sources.mjs",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:package": "npm --prefix desktop run package:dir",
    "test:web": "npm --prefix web run test:unit --"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "lint-staged": {
    "backend/**/*.{ts,tsx}": [
      "bash -lc \"npm --prefix backend run lint\""
    ],
    "web/**/*.{js,jsx,ts,tsx}": [
      "bash -lc \"npm --prefix web run lint\""
    ],
    "desktop/**/*.{js,cjs,mjs,json,yml,md}": [
      "bash -lc \"npm --prefix desktop run lint\""
    ]
  },
  "dependencies": {
    "pg": "^8.18.0"
  }
}
