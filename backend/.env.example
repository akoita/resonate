# ===========================================
# Backend Environment Variables
# ===========================================
# 
# For local development, run `make local-aa-full` which will:
# 1. Start Docker services (PostgreSQL, Anvil, Alto bundler)
# 2. Deploy AA contracts
# 3. Auto-generate backend/.env with all required values
#
# You should NOT need to manually create or edit this file for local dev.
# ===========================================

# Database (auto-set by script)
DATABASE_URL=postgresql://resonate:resonate@localhost:5432/resonate

# JWT Authentication (auto-set by script)
JWT_SECRET=dev-secret-change-in-production

# Account Abstraction - Local Development (auto-set by script after deploy)
AA_ENTRY_POINT=
AA_FACTORY=
AA_KERNEL=
AA_ECDSA_VALIDATOR=
AA_SIG_VALIDATOR=
AA_CHAIN_ID=31337
AA_BUNDLER=http://localhost:4337
AA_PAYMASTER=
AA_STRICT_BUNDLER=                    # Set true to throw on bundler failure (no fallback)

# Stem Processing (Demucs Worker)
# The Demucs worker runs in Docker and uses this URL to POST progress callbacks
# back to the backend. host.docker.internal resolves to the host machine from Docker.
BACKEND_URL=http://host.docker.internal:3000

# ===========================================
# Production/Testnet (manual configuration)
# ===========================================
# ZERODEV_PROJECT_ID=your-project-id  # From dashboard.zerodev.app
# SEPOLIA_RPC_URL=                     # e.g. https://sepolia.infura.io/v3/YOUR_KEY
# BLOCK_EXPLORER_URL=https://sepolia.etherscan.io

# ===========================================
# AI Agent Runtime
# ===========================================
# AGENT_RUNTIME=adk                    # Options: adk (recommended), vertex, langgraph, local (deterministic fallback)
# GOOGLE_AI_API_KEY=                   # Required for adk/vertex modes — from aistudio.google.com
# VERTEX_AI_MODEL=gemini-2.5-flash     # Model name for the curation agent

# ===========================================
# Agent Key Encryption (agent-owned session keys)
# ===========================================
# KMS_PROVIDER=local                   # Options: local (AES-256-GCM), gcp-kms (Cloud KMS). Default: plaintext (dev only!)
# AGENT_KEY_ENCRYPTION_KEY=            # Required when KMS_PROVIDER=local — 64-char hex string (32 bytes)
                                       # Generate: ./scripts/generate-agent-encryption-key.sh
# GCP_KMS_KEY_NAME=                    # Required when KMS_PROVIDER=gcp-kms — full KMS CryptoKey resource name

# ===========================================
# Server Signer Key (wallet deployment)
# ===========================================
AGENT_SIGNER_KEY=                      # Server-side signer private key (64-char hex). Required for wallet deployment.
                                       # Generate: openssl rand -hex 32
                                       # In production: mount from GCP Secret Manager
# AA_FUNDER_KEY=                       # Local dev only: Anvil funder key (defaults to account 0)

# ===========================================
# Stem Processing
# ===========================================
# STEM_PROCESSING_MODE=sync            # Options: sync (in-process), pubsub (GCP Pub/Sub). Default: pubsub
                                       # Set to 'sync' for local dev without Pub/Sub emulator

# ===========================================
# WebAuthn (Passkey) Auth
# ===========================================
# WEBAUTHN_RP_ORIGIN=http://localhost:3001  # Relying party origin for passkey validation

