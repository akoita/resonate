generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id                          String                       @id @default(uuid())
  email                       String                       @unique
  createdAt                   DateTime                     @default(now())
  artist                      Artist?
  agentConfig                 AgentConfig?
  agentSignals                AgentSignal[]
  communityBadges             CommunityBadge[]
  communityMemberships        CommunityMembership[]
  communityCohortMemberships  CommunityCohortMembership[]
  communityMessages           CommunityMessage[]
  communityProfile            CommunityProfile?
  communityRoles              CommunityRole[]
  communityModerationReports  CommunityModerationReport[]
  communityVisibilitySettings CommunityVisibilitySettings?
  communityBenefitRedemptions CommunityBenefitRedemption[]
  tasteMemorySettings         ListenerTasteMemorySettings?
  tasteSignalControls         ListenerTasteSignalControl[]
  folders                     Folder[]
  libraryTracks               LibraryTrack[]
  playlists                   Playlist[]
  sessions                    Session[]
  wallet                      Wallet?
  passkeyIdentities           PasskeyIdentity[]
  sessionKeys                 SessionKey[]
  showCampaignEvents          ShowCampaignEvent[]          @relation("ShowCampaignEventActor")
  showPledges                 ShowPledge[]
  stemQualityRatings          StemQualityRating[]
  remixProjects               RemixProject[]
  reputationFeedbackSubmitted AgentReputationFeedback[]    @relation("AgentReputationFeedbackSubmitter")
}

model Wallet {
  id               String  @id @default(uuid())
  userId           String  @unique
  address          String
  chainId          Int
  balanceUsd       Float   @default(0)
  monthlyCapUsd    Float   @default(0)
  spentUsd         Float   @default(0)
  accountType      String  @default("local")
  provider         String  @default("local")
  ownerAddress     String?
  entryPoint       String?
  factory          String?
  paymaster        String?
  bundler          String?
  salt             String?
  deploymentTxHash String?
  user             User    @relation(fields: [userId], references: [id])
}

model CommunityProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  displayName       String
  bio               String?  @db.Text
  avatarUrl         String?
  profileVisibility String   @default("private")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([profileVisibility, updatedAt])
}

model CommunityVisibilitySettings {
  userId              String   @id
  showTasteBadges     Boolean  @default(false)
  showOwnedItems      Boolean  @default(false)
  showCampaignSupport Boolean  @default(false)
  showShowAttendance  Boolean  @default(false)
  showPlaylists       Boolean  @default(false)
  showWalletAddress   Boolean  @default(false)
  allowTasteMatching  Boolean  @default(false)
  allowCityScenes     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityBadge {
  id         String    @id @default(uuid())
  userId     String
  badgeType  String
  sourceType String
  sourceId   String?
  visibility String    @default("private")
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType, sourceType, sourceId], name: "CommunityBadge_identity")
  @@index([userId, revokedAt])
  @@index([badgeType, sourceType])
  @@index([visibility])
}

model CommunityRole {
  id         String    @id @default(uuid())
  userId     String
  roleType   String
  scopeType  String
  scopeId    String?
  sourceType String
  sourceId   String?
  visibility String    @default("private")
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleType, scopeType, scopeId], name: "CommunityRole_identity")
  @@index([userId, revokedAt])
  @@index([roleType, scopeType])
  @@index([visibility])
}

model CommunityCohort {
  id                 String                      @id @default(uuid())
  cohortType         String
  reasonCode         String
  title              String
  safeExplanation    String                      @db.Text
  minimumSize        Int                         @default(5)
  visibleMemberCount Int                         @default(0)
  status             String                      @default("suggested")
  metadata           Json?
  expiresAt          DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  memberships        CommunityCohortMembership[]

  @@index([cohortType, status, expiresAt])
  @@index([reasonCode, status])
  @@index([status, visibleMemberCount])
}

model CommunityCohortMembership {
  id               String          @id @default(uuid())
  cohortId         String
  userId           String
  status           String          @default("suggested")
  suggestedAt      DateTime        @default(now())
  suggestedEventAt DateTime?
  joinedAt         DateTime?
  leftAt           DateTime?
  hiddenAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  cohort           CommunityCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId], name: "CommunityCohortMembership_identity")
  @@index([userId, status, updatedAt])
  @@index([cohortId, status])
}

model CommunityBenefitRule {
  id                String                         @id @default(uuid())
  artistId          String?
  title             String
  description       String?                        @db.Text
  benefitType       String
  eligibilityPolicy Json
  redemptionPolicy  Json?
  status            String                         @default("draft")
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  artist            Artist?                        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  redemptions       CommunityBenefitRedemption[]

  @@index([artistId, status])
  @@index([benefitType, status])
  @@index([status, startsAt, endsAt])
}

model CommunityBenefitRedemption {
  id                  String               @id @default(uuid())
  benefitRuleId       String
  userId              String
  redemptionStatus    String               @default("redeemed")
  settlementType      String               @default("none")
  settlementReference String?
  redeemedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  benefitRule         CommunityBenefitRule @relation(fields: [benefitRuleId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([benefitRuleId, userId], name: "CommunityBenefitRedemption_identity")
  @@index([userId, redemptionStatus])
  @@index([benefitRuleId, redemptionStatus])
}

model CommunityRoom {
  id               String                       @id @default(uuid())
  roomType         String
  ownerType        String
  ownerId          String
  artistId         String?
  title            String
  description      String?                      @db.Text
  accessPolicyJson Json?
  status           String                       @default("active")
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  artist           Artist?                      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  memberships      CommunityMembership[]
  messages         CommunityMessage[]
  reports          CommunityModerationReport[]

  @@unique([roomType, ownerType, ownerId], name: "CommunityRoom_identity")
  @@index([artistId, status])
  @@index([ownerType, ownerId, status])
  @@index([roomType, status])
}

model CommunityMembership {
  id                         String        @id @default(uuid())
  roomId                     String
  userId                     String
  role                       String        @default("member")
  sourceType                 String        @default("manual")
  status                     String        @default("active")
  joinedAt                   DateTime      @default(now())
  endedAt                    DateTime?
  lastViewedCampaignUpdateId String?
  lastViewedCampaignUpdateAt DateTime?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  room                       CommunityRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user                       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId], name: "CommunityMembership_identity")
  @@index([userId, status])
  @@index([roomId, status])
}

model CommunityMessage {
  id          String                       @id @default(uuid())
  roomId      String
  authorId    String
  body        String                       @db.Text
  messageType String                       @default("message")
  status      String                       @default("visible")
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  deletedAt   DateTime?
  room        CommunityRoom                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author      User                         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reports     CommunityModerationReport[]

  @@index([roomId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([messageType])
}

model CommunityModerationReport {
  id             String            @id @default(uuid())
  roomId         String
  messageId      String?
  reporterUserId String
  reason         String
  status         String            @default("open")
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  room           CommunityRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message        CommunityMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  reporter       User              @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([roomId, status])
  @@index([messageId, status])
  @@index([reporterUserId, createdAt])
}

model CommunityDiscordBridge {
  id                         String                         @id @default(uuid())
  artistId                   String                         @unique
  provider                   String                         @default("discord")
  serverId                   String?
  serverName                 String?
  channelId                  String?
  channelName                String?
  webhookUrl                 String?                        @db.Text
  webhookUrlMasked           String
  inviteUrl                  String?
  publicLinkEnabled          Boolean                        @default(false)
  announcementMirrorEnabled  Boolean                        @default(false)
  roleSyncEnabled            Boolean                        @default(false)
  status                     String                         @default("connected")
  lastTestedAt               DateTime?
  lastMirroredAt             DateTime?
  lastRoleSyncAt             DateTime?
  lastFailureAt              DateTime?
  lastFailureReason          String?                        @db.Text
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  artist                     Artist                         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  roleMappings               CommunityDiscordRoleMapping[]
  syncAttempts               CommunityDiscordSyncAttempt[]

  @@index([artistId, status])
  @@index([publicLinkEnabled, status])
}

model CommunityDiscordRoleMapping {
  id            String                 @id @default(uuid())
  bridgeId      String
  resonateRole  String
  scopeType     String                 @default("artist")
  scopeId       String
  discordRoleId String
  label         String?
  enabled       Boolean                @default(true)
  lastSyncedAt  DateTime?
  lastStatus    String                 @default("pending")
  lastReason    String?                @db.Text
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  bridge        CommunityDiscordBridge @relation(fields: [bridgeId], references: [id], onDelete: Cascade)

  @@unique([bridgeId, resonateRole, scopeType, scopeId, discordRoleId], name: "CommunityDiscordRoleMapping_identity")
  @@index([bridgeId, enabled])
  @@index([resonateRole, scopeType, scopeId])
}

model CommunityDiscordSyncAttempt {
  id             String                  @id @default(uuid())
  bridgeId       String
  action         String
  status         String                  @default("pending")
  messageId      String?
  roleMappingId  String?
  retryOfId      String?
  attemptCount   Int                     @default(1)
  requestSummary Json?
  responseStatus Int?
  errorReason    String?                 @db.Text
  createdAt      DateTime                @default(now())
  completedAt    DateTime?
  bridge         CommunityDiscordBridge  @relation(fields: [bridgeId], references: [id], onDelete: Cascade)

  @@index([bridgeId, action, status, createdAt])
  @@index([messageId])
  @@index([roleMappingId])
  @@index([retryOfId])
}

model SignupFaucetAttempt {
  id            String   @id @default(uuid())
  userId        String
  walletAddress String
  chainId       Int
  purpose       String   @default("signup-sepolia-faucet")
  amountWei     String
  status        String
  txHash        String?
  failureReason String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, walletAddress, chainId, purpose], name: "signupFaucetAttempt_identity", map: "SignupFaucetAttempt_signupFaucetAttempt_identity_key")
  @@index([walletAddress, chainId], map: "SignupFaucetAttempt_walletAddress_chainId_idx")
}

model PasskeyIdentity {
  id                 String   @id @default(uuid())
  publicKeyHash      String   @unique
  userId             String
  firstWalletAddress String?
  lastWalletAddress  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lastWalletAddress])
}

model Artist {
  id                        String                        @id @default(uuid())
  userId                    String?                       @unique
  displayName               String
  payoutAddress             String?
  profileType               String                        @default("manager")
  claimStatus               String                        @default("claimed")
  imageUrl                  String?
  summary                   String?                       @db.Text
  socialLinks               Json?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  user                      User?                         @relation(fields: [userId], references: [id])
  releases                  Release[]
  releaseCredits            ReleaseArtistCredit[]
  creatorTrust              CreatorTrust?
  rightsUpgradeRequests     ReleaseRightsUpgradeRequest[]
  showCampaigns             ShowCampaign[]
  communityBenefitRules     CommunityBenefitRule[]
  communityRooms            CommunityRoom[]
  discordBridge             CommunityDiscordBridge?
  trustedSourceLinks        TrustedSourceArtistLink[]
  trustedSourceLinkRequests TrustedSourceLinkRequest[]

  @@index([displayName])
  @@index([profileType, claimStatus])
}

model Release {
  id                    String                        @id @default(uuid())
  artistId              String
  title                 String
  status                String                        @default("processing")
  processingError       String?                       @db.Text
  type                  String                        @default("single")
  primaryArtist         String?
  featuredArtists       String?
  genre                 String?
  moods                 String[]                      @default([])
  label                 String?
  releaseDate           DateTime?
  explicit              Boolean                       @default(false)
  createdAt             DateTime                      @default(now())
  artworkUrl            String?
  artworkData           Bytes?
  artworkMimeType       String?
  attestation           String?                       @db.Text // JSON: {contentHash, isOriginalWork, sourceCredits[]}
  attestationSignature  String?                       @db.Text // Wallet signature of the attestation
  rightsRoute           String?
  rightsFlags           Json?
  rightsReason          String?                       @db.Text
  rightsPolicyVersion   String?
  rightsSourceType      String?
  rightsEvaluatedAt     DateTime?
  artist                Artist                        @relation(fields: [artistId], references: [id])
  artistCredits         ReleaseArtistCredit[]
  tracks                Track[]
  rightsUpgradeRequests ReleaseRightsUpgradeRequest[]
  rightsReassessments   RightsRouteReassessment[]

  @@index([rightsRoute])
}

model ReleaseArtistCredit {
  id          String   @id @default(uuid())
  releaseId   String
  artistId    String
  role        String
  displayName String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  artist      Artist   @relation(fields: [artistId], references: [id])

  @@unique([releaseId, role, artistId, sortOrder])
  @@index([artistId, role])
  @@index([releaseId, role, sortOrder])
  @@index([displayName, role])
}

model Track {
  id                  String            @id @default(uuid())
  title               String
  isrc                String?
  explicit            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  position            Int               @default(1)
  releaseId           String
  artist              String?
  processingStatus    String            @default("pending") // pending, processing, complete, failed
  processingError     String?           @db.Text
  processingStartedAt DateTime?
  lastProgressAt      DateTime?
  contentStatus       String            @default("clean") // clean, quarantined, dmca_removed
  generationMetadata  Json? // { provider, prompt, negativePrompt, seed, generatedAt, synthIdPresent, durationSeconds, sampleRate, cost }
  licenses            License[]
  agentSignals        AgentSignal[]
  stems               Stem[]
  embedding           TrackEmbedding?
  fingerprint         AudioFingerprint?
  dmcaReports         DmcaReport[]
  release             Release           @relation(fields: [releaseId], references: [id])
  remixProjects       RemixProject[]
  rightsRoute         String?
  rightsFlags         Json?
  rightsReason        String?           @db.Text
  rightsPolicyVersion String?
  rightsEvaluatedAt   DateTime?

  @@index([rightsRoute])
}

model TrackEmbedding {
  trackId   String                    @id
  vector    Unsupported("vector(16)")
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  track     Track                     @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model Stem {
  id                 String              @id @default(uuid())
  trackId            String
  type               String
  uri                String
  ipnftId            String?
  checksum           String?
  artist             String?
  artworkUrl         String?
  title              String?
  data               Bytes?
  mimeType           String?
  durationSeconds    Float?
  encryptionMetadata String?
  isEncrypted        Boolean             @default(false)
  storageProvider    String              @default("local")
  track              Track               @relation(fields: [trackId], references: [id])
  listings           StemListing[]
  nftMint            StemNftMint?
  pricing            StemPricing?
  qualityRatings     StemQualityRating[]
  remixProjectStems  RemixProjectStem[]
  x402Settlements    X402Settlement[]
}

model StemQualityRating {
  id                      String    @id @default(uuid())
  stemId                  String
  curatorUserId           String
  curatorAgentConfigId    String?
  curatorIdentityRegistry String?
  curatorIdentityTokenId  String?
  score                   Int
  rmsEnergy               Float
  spectralDensity         Float
  silenceRatio            Float
  musicalSalience         Float
  confidence              Float     @default(0)
  taskType                String    @default("stem.quality_rating")
  analysisMethod          String
  analysisMetadata        Json?
  analysisUri             String?
  onchainMetadataKey      String?
  onchainTaskHash         String?
  onchainTxHash           String?
  onchainStatus           String    @default("local")
  onchainError            String?   @db.Text
  purchaseValidationCount Int       @default(0)
  skipValidationCount     Int       @default(0)
  reputationDelta         Int       @default(0)
  lastValidatedAt         DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  stem                    Stem      @relation(fields: [stemId], references: [id], onDelete: Cascade)
  curator                 User      @relation(fields: [curatorUserId], references: [id], onDelete: Cascade)

  @@unique([stemId, curatorUserId])
  @@index([stemId, score])
  @@index([curatorUserId, createdAt])
  @@index([onchainTaskHash])
}

model StemPricing {
  id                   String   @id @default(uuid())
  stemId               String   @unique
  basePlayPriceUsd     Float    @default(0.05)
  remixLicenseUsd      Float    @default(5.0)
  commercialLicenseUsd Float    @default(25.0)
  floorUsd             Float    @default(0.01)
  ceilingUsd           Float    @default(50.0)
  listingDurationDays  Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  stem                 Stem     @relation(fields: [stemId], references: [id])
}

model StemNftMint {
  id              String   @id @default(uuid())
  stemId          String   @unique
  tokenId         BigInt
  chainId         Int
  contractAddress String
  creatorAddress  String
  royaltyBps      Int
  remixable       Boolean
  metadataUri     String
  transactionHash String
  blockNumber     BigInt
  mintedAt        DateTime
  createdAt       DateTime @default(now())
  stem            Stem     @relation(fields: [stemId], references: [id])

  @@unique([transactionHash, tokenId], name: "transactionHash_tokenId")
  @@index([tokenId, chainId])
  @@index([creatorAddress])
}

model StemListing {
  id              String           @id @default(uuid())
  listingId       BigInt
  stemId          String?
  tokenId         BigInt
  chainId         Int
  contractAddress String
  sellerAddress   String
  pricePerUnit    String
  amount          BigInt
  paymentToken    String
  expiresAt       DateTime
  transactionHash String
  blockNumber     BigInt
  licenseType     LicenseType      @default(personal)
  status          String           @default("active")
  listedAt        DateTime
  soldAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime         @default(now())
  stem            Stem?            @relation(fields: [stemId], references: [id])
  purchases       StemPurchase[]
  x402Settlements X402Settlement[]

  @@unique([transactionHash, listingId], name: "transactionHash_listingId")
  @@index([listingId, chainId])
  @@index([sellerAddress])
  @@index([tokenId, chainId])
  @@index([licenseType])
  @@index([status])
}

model StemListingIntent {
  id              String      @id @default(uuid())
  transactionHash String
  tokenId         BigInt?
  stemId          String?
  chainId         Int
  sellerAddress   String?
  pricePerUnit    String?
  amount          BigInt?
  paymentToken    String?
  licenseType     LicenseType @default(personal)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([transactionHash, tokenId], name: "transactionHash_tokenId")
  @@index([transactionHash])
  @@index([stemId])
  @@index([licenseType])
}

// License type enum — matches RFC #310 License NFT Schema
// Phase 1 uses personal/remix/commercial; others reserved for Phase 4+
enum LicenseType {
  personal
  remix
  commercial
  sync
  sample
  broadcast
}

model StemPurchase {
  id                    String      @id @default(uuid())
  listingId             String
  buyerAddress          String
  amount                BigInt
  totalPaid             String
  paymentToken          String      @default("0x0000000000000000000000000000000000000000")
  paymentAssetId        String?
  paymentAssetSymbol    String      @default("ETH")
  paymentAssetDecimals  Int         @default(18)
  settlementAmount      String?
  settlementAmountUnits String?
  canonicalAmountUsd    String?
  royaltyPaid           String
  protocolFeePaid       String
  sellerReceived        String
  licenseType           LicenseType @default(personal)
  transactionHash       String      @unique
  blockNumber           BigInt
  purchasedAt           DateTime
  createdAt             DateTime    @default(now())
  listing               StemListing @relation(fields: [listingId], references: [id])

  @@index([buyerAddress])
  @@index([purchasedAt])
  @@index([licenseType])
}

model RoyaltyPayment {
  id                    String   @id @default(uuid())
  tokenId               BigInt
  chainId               Int
  recipientAddress      String
  amount                String
  paymentToken          String   @default("0x0000000000000000000000000000000000000000")
  paymentAssetId        String?
  paymentAssetSymbol    String   @default("ETH")
  paymentAssetDecimals  Int      @default(18)
  settlementAmount      String?
  settlementAmountUnits String?
  canonicalAmountUsd    String?
  transactionHash       String
  blockNumber           BigInt
  paidAt                DateTime
  createdAt             DateTime @default(now())

  @@unique([transactionHash, tokenId], name: "transactionHash_tokenId")
  @@index([recipientAddress])
  @@index([tokenId, chainId])
  @@index([paidAt])
}

model ContractEvent {
  id              String    @id @default(uuid())
  eventName       String
  chainId         Int
  contractAddress String
  transactionHash String
  logIndex        Int
  blockNumber     BigInt
  blockHash       String
  args            Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@unique([transactionHash, logIndex])
  @@index([eventName])
  @@index([blockNumber])
  @@index([contractAddress, chainId])
}

model X402Settlement {
  id                          String       @id @default(uuid())
  stemId                      String
  listingId                   String?
  listingChainId              Int?
  listingContractAddress      String?
  listingTokenId              BigInt?
  payerAddress                String?
  paymentRail                 String       @default("facilitator")
  paymentProofSha256          String?      @unique
  paymentTransactionHash      String?      @unique
  receiptId                   String       @unique
  receipt                     Json
  status                      String       @default("download_granted")
  contractSettlementStatus    String       @default("not_applicable")
  contractSettlementTxHash    String?
  contractSettlementEventName String?
  contractSettlementReason    String?
  paymentToken                String
  paymentAssetId              String?
  paymentAssetSymbol          String
  paymentAssetDecimals        Int
  settlementAmount            String
  settlementAmountUnits       String
  canonicalAmountUsd          String?
  purchasedAt                 DateTime
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  stem                        Stem         @relation(fields: [stemId], references: [id])
  listing                     StemListing? @relation(fields: [listingId], references: [id])

  @@index([stemId])
  @@index([status])
  @@index([contractSettlementStatus])
}

model RemixProject {
  id                 String             @id @default(uuid())
  creatorUserId      String
  sourceTrackId      String
  title              String
  status             String             @default("draft") // draft, archived
  mode               String             @default("stem_mix") // stem_mix, variation, extension
  licenseType        LicenseType        @default(remix)
