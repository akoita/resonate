# ---- Stage 1: Dependencies ----
FROM node:20-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json .npmrc ./
RUN npm install -g npm@11.14.1
RUN npm ci --legacy-peer-deps

# ---- Stage 2: Build ----
FROM node:20-alpine AS build
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build-time args for NEXT_PUBLIC_* (baked into the JS bundle at compile time)
ARG NEXT_PUBLIC_ZERODEV_PROJECT_ID=""
ARG NEXT_PUBLIC_API_URL=""
ARG NEXT_PUBLIC_CHAIN_ID="11155111"
ARG NEXT_PUBLIC_STEM_NFT_ADDRESS=""
ARG NEXT_PUBLIC_MARKETPLACE_ADDRESS=""
ARG NEXT_PUBLIC_TRANSFER_VALIDATOR_ADDRESS=""
ARG NEXT_PUBLIC_CONTENT_PROTECTION_ADDRESS=""
ARG NEXT_PUBLIC_DISPUTE_RESOLUTION_ADDRESS=""
ARG NEXT_PUBLIC_CURATION_REWARDS_ADDRESS=""
ARG NEXT_PUBLIC_RPC_URL=""
ARG NEXT_PUBLIC_AA_BUNDLER=""
ARG NEXT_PUBLIC_PIMLICO_API_KEY=""
ARG NEXT_PUBLIC_PASSKEY_SERVER_URL=""
ARG NEXT_PUBLIC_PASSKEY_RP_ID=""
ARG NEXT_PUBLIC_ENV=""

ENV NEXT_PUBLIC_ZERODEV_PROJECT_ID=$NEXT_PUBLIC_ZERODEV_PROJECT_ID
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_CHAIN_ID=$NEXT_PUBLIC_CHAIN_ID
ENV NEXT_PUBLIC_STEM_NFT_ADDRESS=$NEXT_PUBLIC_STEM_NFT_ADDRESS
ENV NEXT_PUBLIC_MARKETPLACE_ADDRESS=$NEXT_PUBLIC_MARKETPLACE_ADDRESS
ENV NEXT_PUBLIC_TRANSFER_VALIDATOR_ADDRESS=$NEXT_PUBLIC_TRANSFER_VALIDATOR_ADDRESS
ENV NEXT_PUBLIC_CONTENT_PROTECTION_ADDRESS=$NEXT_PUBLIC_CONTENT_PROTECTION_ADDRESS
ENV NEXT_PUBLIC_DISPUTE_RESOLUTION_ADDRESS=$NEXT_PUBLIC_DISPUTE_RESOLUTION_ADDRESS
ENV NEXT_PUBLIC_CURATION_REWARDS_ADDRESS=$NEXT_PUBLIC_CURATION_REWARDS_ADDRESS
ENV NEXT_PUBLIC_RPC_URL=$NEXT_PUBLIC_RPC_URL
ENV NEXT_PUBLIC_AA_BUNDLER=$NEXT_PUBLIC_AA_BUNDLER
ENV NEXT_PUBLIC_PIMLICO_API_KEY=$NEXT_PUBLIC_PIMLICO_API_KEY
ENV NEXT_PUBLIC_PASSKEY_SERVER_URL=$NEXT_PUBLIC_PASSKEY_SERVER_URL
ENV NEXT_PUBLIC_PASSKEY_RP_ID=$NEXT_PUBLIC_PASSKEY_RP_ID
ENV NEXT_PUBLIC_ENV=$NEXT_PUBLIC_ENV

# Build Next.js with standalone output
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ---- Stage 3: Production Runtime ----
FROM node:20-alpine
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Copy standalone server + static assets
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public

EXPOSE 3000

USER node

CMD ["node", "server.js"]
