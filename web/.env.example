# ZeroDev Configuration
NEXT_PUBLIC_ZERODEV_PROJECT_ID=
# Optional full hosted passkey server URL. If it ends with a ZeroDev project
# UUID, the frontend derives NEXT_PUBLIC_ZERODEV_PROJECT_ID from it.
# NEXT_PUBLIC_PASSKEY_SERVER_URL=
# Optional WebAuthn relying-party ID override. Use only when recovering or
# intentionally sharing passkeys across subdomains.
# NEXT_PUBLIC_PASSKEY_RP_ID=

# Chain Configuration
NEXT_PUBLIC_CHAIN_ID=31337
# NEXT_PUBLIC_RPC_URL=              # Override RPC (e.g. http://localhost:8545 for forked Sepolia)
# NEXT_PUBLIC_AA_PAYMASTER_ENABLED= # Set true only when browser UserOps should use configured gas sponsorship.

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Deployment environment label shown in the in-app About modal and the
# header badge next to the Resonate wordmark. Leave unset (or set to
# "production") in prod so the badge stays hidden. Recognized non-prod
# values: "local", "staging", "preview", "development".
NEXT_PUBLIC_ENV=
